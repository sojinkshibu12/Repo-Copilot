# ── LLM Provider ──────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ── Embedding Provider ────────────────────────────────────────────────
# One of: openai, google, local (sentence-transformers), mock
EMBEDDING_PROVIDER=google
# Model name (defaults per provider: text-embedding-3-small, text-embedding-004, all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Provider API Keys ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
OLLAMA_BASE_URL=http://localhost:11434

# ── GitHub ────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WATCHED_REPO=owner/repo
GITHUB_WEBHOOK_SECRET=...

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/repocopilot

# ── Vector Store ──────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Tracing ────────────────────────────────────────────────────────────
# One of: json (json log lines), console (stdout lines), none (no-op)
TRACE_EMITTER=json

# ── App ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_TOKENS_PER_SESSION=100000
